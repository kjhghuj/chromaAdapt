# ChromaAdapt AI 环境变量配置
# 复制此文件为 .env 并填写实际值

# ==============================================
# API 密钥配置
# ==============================================
ARK_API_KEY=你的ARK_API_KEY
ARK_ENDPOINT_ID=你的Doubao-Seedream-4.5-Endpoint-ID
ARK_ENDPOINT_ID_SEEDREAM_5_LITE=你的Doubao-Seedream-5.0-lite-Endpoint-ID
ARK_ANALYSIS_ENDPOINT_ID=你的Doubao-Seed-2.0-lite-Endpoint-ID
ARK_ANALYSIS_ENDPOINT_ID_SEED_2_MINI=你的Doubao-Seed-2.0-mini-Endpoint-ID
ARK_ANALYSIS_ENDPOINT_ID_SEED_2_PRO=你的Doubao-Seed-2.0-pro-Endpoint-ID

# ==============================================
# Webhook 配置
# ==============================================
WEBHOOK_SECRET=你的Webhook密码

# ==============================================
# 项目路径（Docker 容器内）
# ==============================================
PROJECT_DIR=/opt/chromaadapt-ai
DEPLOY_SCRIPT=/opt/chromaadapt-ai/backend/deploy_docker.sh
